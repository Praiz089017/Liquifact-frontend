# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

CLAUDE.md
plan.md

# ── Repo hygiene: block Rust/binary artifacts ──────────────────────────────
# Rust manifests and lock files have no place in the JS frontend root
Cargo.toml
Cargo.lock

# Compiled Rust / WASM binaries and Windows installers
*.exe
*.wasm
*.so
*.dylib
rustup-init*

# Rust source directories that belong in a separate contracts repo
/src/*.rs
/contracts/
/examples/*.rs
/test_snapshots/

# ── Repo hygiene: block generated PR-body / one-off note files ──────────────
# Transient PR description files generated by tooling
PR_BODY_*.md
PR_DESCRIPTION*.md
# One-off implementation notes (archive to docs/ before committing)
ISSUE_*_IMPLEMENTATION.md
ISSUE_*_FLOW_DIAGRAM.md
# Delivery checklists and refactoring summaries (not persistent docs)
DELIVERY_CHECKLIST.md
*_REFACTOR_SUMMARY.md
REFACTORING_*.md
*_IMPLEMENTATION_SUMMARY.md
*_INTEGRATION_SUMMARY.md
IMPLEMENTATION_COMPLETE.md
*_QUICK_REFERENCE.md
LEDGER_GAP_TESTS.md
